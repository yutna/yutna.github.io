---
import Container from "@/components/container.astro";
import LayoutDefault from "@/layouts/layout-default.astro";
import { getPosts } from "@/lib/get-posts";
import { formatPostSlugPath } from "@/utils/format-post-slug-path";

import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts.map((post) => {
    const slug = formatPostSlugPath(post.data.publishedDate, post.slug);

    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<LayoutDefault pageTitle={post.data.title}>
  <Container>
    <article class="my-4">
      <h1>{post.data.title}</h1>
      <div class="prose mt-8 max-w-none">
        <Content />
      </div>
    </article>

    <section>
      <h2>
        <a class="hover:text-blue-400 hover:underline" href="/tags">แท็ก</a>
      </h2>
      <ul class="my-4 flex gap-4">
        {
          post.data.tags.map((tag) => (
            <li>
              <a
                class="hover:text-blue-400 hover:underline"
                href={`/tags/${tag}`}
              >
                {tag}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </Container>
</LayoutDefault>
