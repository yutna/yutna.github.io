---
import Container from "@/components/container.astro";
import LayoutDefault from "@/layouts/layout-default.astro";
import { getPosts } from "@/lib/get-posts";
import { getTags } from "@/lib/get-tags";
import { formatPostSlugPath } from "@/utils/format-post-slug-path";

export async function getStaticPaths() {
  const allPosts = await getPosts();
  const tags = await getTags();

  return tags.map((tag) => {
    const posts = allPosts.filter((post) => post.data.tags.includes(tag));
    return { params: { tag }, props: { posts } };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const pageTitle = `แท็ก - ${tag}`;
---

<LayoutDefault pageTitle={pageTitle} pageDescription="">
  <Container>
    <main>
      <h1>{pageTitle}</h1>
      <h2>บทความที่เกี่ยวกับแท็ก {tag} ทั้งหมด</h2>
      <ul>
        {
          posts.map((post) => (
            <li>
              <a href={formatPostSlugPath(post.data.publishedDate, post.slug)}>
                {post.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </Container>
</LayoutDefault>
